# Top level makefile for qe-converse  (generated by configure from Makefile.in)

QE_SOURCE=@qe_source@

all:    build

build:
	@echo "Building qe-converse..."
	$(MAKE) -C src
	@mkdir -p bin
	@cd bin && ln -sf ../src/qe-converse.x .

test:
	$(MAKE) -C tests QE_SRC_DIR=$(QE_SOURCE)

test-integration:
	$(MAKE) -C tests integration QE_SRC_DIR=$(QE_SOURCE)


clean:
	@echo "Cleaning qe-converse..."
	if test -s src/Makefile ; then ( $(MAKE) -C src clean ); fi
	-/bin/rm -f bin/qe-converse.x

distclean:
	$(MAKE) -C src distclean
	-/bin/rm -f config.log config.status makedeps.sh Makefile
	-/bin/rm -Rf autom4te.cache
